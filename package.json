{
  "name": "gonggu-wish",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:mobile": "turbo run build --filter=@gonggu/mobile",
    "build:web": "turbo run build --filter=@gonggu/web",
    "build:api": "turbo run build --filter=@gonggu/api",
    "build:shared": "turbo run build --filter=@gonggu/shared",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "db:generate": "turbo run db:generate --filter=@gonggu/api",
    "db:migrate": "turbo run db:migrate --filter=@gonggu/api",
    "api:dev": "turbo run dev --filter=@gonggu/api",
    "mobile:start": "turbo run start --filter=@gonggu/mobile",
    "web:dev": "turbo run dev --filter=@gonggu/web",
    "admin:dev": "turbo run dev --filter=@gonggu/admin",
    "admin:build": "turbo run build --filter=@gonggu/admin",
    "admin:typecheck": "turbo run typecheck --filter=@gonggu/admin",
    "admin:lint": "turbo run lint --filter=@gonggu/admin",
    "admin:test": "turbo run test --filter=@gonggu/admin",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky install",
 "test:e2e:admin": "turbo run test:e2e --filter=@gonggu/admin",
 "test:e2e:web": "turbo run test:e2e --filter=@gonggu/web",
 "test:e2e:mobile": "powershell -ExecutionPolicy Bypass -File scripts/maestro-e2e-with-recording.ps1 -Flows .maestro/mobile-e2e-evidence-flow.yaml",
 "test:e2e:mobile:all": "powershell -ExecutionPolicy Bypass -File scripts/maestro-e2e-with-recording.ps1 -Flows .maestro/home-nav-flow.yaml,.maestro/calendar-flow.yaml,.maestro/search-filter-flow.yaml,.maestro/search-empty-recovery-flow.yaml,.maestro/calendar-following-filter-flow.yaml,.maestro/submit-form-flow.yaml,.maestro/submit-validation-flow.yaml,.maestro/reels-flow.yaml,.maestro/detail-flow.yaml,.maestro/store-flow.yaml,.maestro/mypage-flow.yaml,.maestro/no-hscroll-flow.yaml,.maestro/full-app-flow.yaml",
 "test:e2e:mobile:user-journeys": "powershell -ExecutionPolicy Bypass -File scripts/maestro-e2e-with-recording.ps1 -Flows .maestro/search-empty-recovery-flow.yaml,.maestro/calendar-following-filter-flow.yaml,.maestro/submit-validation-flow.yaml",
 "test:e2e:mobile:nav": "powershell -ExecutionPolicy Bypass -File scripts/maestro-e2e-with-recording.ps1 -Flows .maestro/home-nav-flow.yaml",
    "mobile:android:build:win": "powershell -ExecutionPolicy Bypass -File scripts/android-build-install.ps1",
 "test:e2e:mobile:smoke": "powershell -ExecutionPolicy Bypass -File scripts/maestro-e2e-with-recording.ps1 -Flows apps/mobile/.maestro/smoke.yaml",
 "test:e2e:mobile:smoke:win": "powershell -ExecutionPolicy Bypass -File scripts/maestro-e2e-with-recording.ps1 -Flows apps/mobile/.maestro/smoke.yaml",
 "e2e:dashboard": "node e2e-dashboard/server.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "react-native-worklets": "^0.7.1",
    "expo": "~55.0.26",
    "react": "19.2.0",
    "react-native": "0.86.0"
  }
}
