# HikerAPI (Instagram media lookup) — Optional
# Set HIKER_API_KEY for live API calls, HIKER_MOCK=true to force mock mode even with a key.
# HIKER_API_KEY=""
# HIKER_MOCK="true"

# umans.ai (LLM product-name inference in hiker-lookup edge function) — Optional
# When set, the admin Hiker lookup enriches the caption with LLM-extracted
# productName/brandName/category/discountInfo. When absent, the function
# silently falls back to client-side rule-based inference.
# Register as a Supabase secret: supabase secrets set UMANS_API_KEY=sk-...
# UMANS_API_KEY=""
# UMANS_MODEL="umans-flash"
# UMANS_API_BASE="https://api.code.umans.ai/v1/chat/completions"
