# Expo's `preview` variable bucket stores the Preview credentials.
# Pull them with `npx eas env:pull --environment preview`.
# Never commit the resulting .env.local file or a real Firebase service file.
APP_VARIANT=preview
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-preview-supabase-anon-key
EXPO_PUBLIC_SUPABASE_URL=https://your-preview-project.supabase.co
EXPO_PUBLIC_API_PROXY_URL=https://api-preview.gongguwish.com
GOOGLE_SERVICES_JSON=./google-services.preview.json
