# Expo's default `preview` variable bucket stores the Staging credentials.
# Pull them with `npx eas env:pull --environment preview`.
# Never commit the resulting .env.local file or a real Firebase service file.
APP_VARIANT=staging
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-staging-supabase-anon-key
EXPO_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
EXPO_PUBLIC_API_PROXY_URL=https://api-staging.gongguwish.com
GOOGLE_SERVICES_JSON=./google-services.staging.json
