{
  "expo": {
    "name": "GongGu Wish",
    "slug": "gonggu-wish",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "gongguwish",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gonggu.wish"
    },
    "android": {
      "package": "com.gonggu.wish",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "typedRoutes": false
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
