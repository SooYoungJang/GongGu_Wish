{
  "expo": {
    "name": "공구위시",
    "slug": "gonggu-wish",
    "version": "0.1.0",
    "updates": {
      "url": "https://u.expo.dev/7425b02f-80fe-4ccf-b7fa-c6052282fe35"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#ffffff",
    "icon": "./assets/app-icon.png",
    "scheme": "gongguwish",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "backgroundColor": "#0f172a",
      "userInterfaceStyle": "automatic",
      "bundleIdentifier": "com.gonggu.wish",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.gonggu.wish",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "typedRoutes": false
    },
    "plugins": [
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F0445E"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7425b02f-80fe-4ccf-b7fa-c6052282fe35"
      }
    },
    "owner": "sooyoung.jang"
  }
}
